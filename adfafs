<!DOCTYPE html>
<html>
<head>
  <title>Restaurant Menu</title>

  <style>
    body {
      font-family: Arial, sans-serif;
      background: #f5f5f5;
      margin: 0;
      padding: 0;
      display: flex;
      justify-content: center;
    }

    .menu {
      width: 400px;
      background: white;
      margin-top: 40px;
      padding: 20px;
      border-radius: 12px;
      box-shadow: 0 0 15px rgba(0,0,0,0.2);
    }

    h1 {
      text-align: center;
      color: #d35400;
      margin-bottom: 10px;
    }

    .subtitle {
      text-align: center;
      color: gray;
      margin-bottom: 20px;
    }

    .item {
      display: flex;
      justify-content: space-between;
      padding: 10px 0;
      border-bottom: 1px solid #eee;
    }

    .item:last-child {
      border-bottom: none;
    }

    .name {
      font-weight: bold;
    }

    .price {
      color: #27ae60;
      font-weight: bold;
    }

    .footer {
      text-align: center;
      margin-top: 15px;
      font-size: 12px;
      color: gray;
    }
  </style>
</head>

<body>

  <div class="menu">
    <h1>MJ Restaurant</h1>
    <div class="subtitle">Fresh • Tasty • Delicious</div>

    <div class="item">
      <div class="name">Pizza</div>
      <div class="price">₹299</div>
    </div>

    <div class="item">
      <div class="name">Burger</div>
      <div class="price">₹149</div>
    </div>

    <div class="item">
      <div class="name">Pasta</div>
      <div class="price">₹199</div>
    </div>

    <div class="item">
      <div class="name">Cold Coffee</div>
      <div class="price">₹99</div>
    </div>

    <div class="footer">
      Thank you for visiting ❤️
    </div>
  </div>

</body>
</html>